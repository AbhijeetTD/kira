# ──────────────────────────────────────────────────────────────────────────────
# KIRA — Environment Configuration
# 1. Copy this file:  cp .env.example .env
# 2. Fill in the values below
# 3. Never commit .env — it's in .gitignore
# ──────────────────────────────────────────────────────────────────────────────


# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  1. OLLAMA (Local LLM) — REQUIRED                                           │
# └─────────────────────────────────────────────────────────────────────────────┘
# Install Ollama: brew install ollama
# Start Ollama:   ollama serve
# Pull a model:   ollama pull llama3.2

OLLAMA_BASE_URL=http://localhost:11434/v1

# Model to use — must be pulled first with: ollama pull <model>
# Options: llama3.2 (fast, 2GB) | llama3.1:8b (best, 5GB) | mistral | qwen2.5:7b
OLLAMA_MODEL=llama3.2


# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  2. KUBERNETES — REQUIRED                                                   │
# └─────────────────────────────────────────────────────────────────────────────┘
# Find your context name: kubectl config get-contexts
# kind cluster default name is usually: kind-<cluster-name>
# Example for kind:      KUBE_CONTEXT=kind-dev-cluster
# Example for minikube:  KUBE_CONTEXT=minikube

KUBE_CONTEXT=kind-dev-cluster

# Namespace KIRA will monitor and remediate
# Use "default" for local dev, or your app namespace (e.g. "production", "staging")
DEFAULT_NAMESPACE=default


# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  3. KIRA BEHAVIOUR — OPTIONAL (defaults work fine)                          │
# └─────────────────────────────────────────────────────────────────────────────┘
# Public URL of this server (used in notification links)
PUBLIC_URL=http://localhost:8000

# Auto-approve remediation if confidence >= this % (0-100)
# Set to 100 to always require manual approval
# Set to 0 to always auto-fix without asking
AUTO_APPROVE_THRESHOLD=90

# true  = require human approval when confidence < AUTO_APPROVE_THRESHOLD
# false = never ask for approval (fully autonomous)
APPROVAL_MODE=true


# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  4. JIRA — OPTIONAL                                                         │
# │  Automatically creates and closes tickets for every incident                │
# └─────────────────────────────────────────────────────────────────────────────┘
# Set JIRA_ENABLED=true to turn on Jira integration

JIRA_ENABLED=false

# Your Jira Cloud URL (e.g. https://your-company.atlassian.net)
JIRA_URL=

# Your Jira account email address
JIRA_EMAIL=

# API token — generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# Project key — shown in brackets next to your project name in Jira (e.g. KS, OPS, INFRA)
JIRA_PROJECT_KEY=KS

# Type of Jira issue to create (Task | Bug | Story)
JIRA_ISSUE_TYPE=Task


# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  5. MICROSOFT TEAMS — OPTIONAL                                              │
# │  Sends incident alerts and resolution summaries to a Teams channel          │
# └─────────────────────────────────────────────────────────────────────────────┘
# How to get the webhook URL:
#   Teams → channel → ··· → Connectors → Incoming Webhook → Copy URL

TEAMS_WEBHOOK_URL=
