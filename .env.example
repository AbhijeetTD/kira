# ──────────────────────────────────────────────────────────────────────────────
# KIRA — .env.example  (Ollama + kind)
# Copy to .env and edit as needed.
# ──────────────────────────────────────────────────────────────────────────────

# Ollama — local LLM
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2          # or: mistral, qwen2.5:7b, llama3.1:8b

# Kubernetes (kind)
KUBE_CONTEXT=kind-dev-cluster  # run: kubectl config get-contexts
DEFAULT_NAMESPACE=default

# App
PUBLIC_URL=http://localhost:8000
AUTO_APPROVE_THRESHOLD=90
APPROVAL_MODE=true

# Optional integrations — leave blank to disable
TEAMS_WEBHOOK_URL=
JIRA_ENABLED=false
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
